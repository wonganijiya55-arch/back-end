# Server Configuration
port=5000

# JWT Secret Key for authentication
JWT_SECRET_KEY=your_secret_key_here

# Database Configuration
# Internal URL for Render internal connections (used automatically when RENDER=true)
# Format: postgresql://<user>:<password>@<internal-host>/<database>
DATABASE_URL_INTERNAL=postgresql://ices_database_user:<password>@dpg-d70oipk9c44c73b55om0-a/ices_database

# External URL — used locally and for connections outside Render's network
# Format: postgresql://<user>:<password>@<external-host>.frankfurt-postgres.render.com/<database>
DATABASE_URL_EXTERNAL=postgresql://ices_database_user:<password>@dpg-d70oipk9c44c73b55om0-a.frankfurt-postgres.render.com/ices_database

# Fallback URL (used for local development when the above are not set)
DATABASE_URL=postgresql://ices_database_user:<password>@dpg-d70oipk9c44c73b55om0-a.frankfurt-postgres.render.com/ices_database

# SSL mode required by Render
PGSSLMODE=require

# Flask Environment (optional)
FLASK_ENV=development

# Email Configuration (for password reset functionality)
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_password_or_app_password
